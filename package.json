{
  "name": "rawagon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RAWagon Network — blockchain-native payment and identity infrastructure on Base L2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "lint:fix": "eslint . --ext .ts,.tsx,.js --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/seed-compiler-cache.mjs",
    "compile": "hardhat compile",
    "clean": "rimraf dist packages/*/dist apps/*/dist artifacts cache"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "hardhat": "^3.2.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "solc": "^0.8.24",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
