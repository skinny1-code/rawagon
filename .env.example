# ── Blockchain ──────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
ETH_RPC_URL=https://eth.llamarpc.com
PRIVATE_KEY=0x...your_deployer_key_here
BASESCAN_API_KEY=your_basescan_key_here

# ── Chainlink (GTX/STX oracle) ───────────────
CHAINLINK_XAU_USD=0x214eD9Da11D2fbe465a6fc601a91E62EbEc1a0D6
CHAINLINK_XAG_USD=0x379589227b15F1a12195D3f2d90bBc9F31f95235

# ── Optional API keys (all free tiers work) ──
BLS_API_KEY=                  # optional, higher rate limits
ALCHEMY_BASE_KEY=             # optional, for Alchemy Base RPC
INFURA_KEY=                   # optional

# ── App config ────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_LTN_ADDRESS=0x...
NEXT_PUBLIC_FEE_DISTRIBUTOR=0x...
NEXT_PUBLIC_BUSINESS_REGISTRY=0x...

# ── Internal ──────────────────────────────────
JWT_SECRET=change_this_to_a_random_256bit_secret
SESSION_SECRET=change_this_too
NODE_ENV=development
